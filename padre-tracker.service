[Unit]
Description=Padre Alpha Tracker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=cokle
WorkingDirectory=/home/cokle/padre-tracker
ExecStart=/usr/bin/xvfb-run -a /home/cokle/padre-tracker/.venv/bin/python main.py
Restart=always
RestartSec=15
Environment=LOG_LEVEL=INFO

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
