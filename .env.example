# Padre Alpha Tracker Scraper Configuration

# How often to poll the Alpha Tracker (seconds)
POLL_INTERVAL=30

# Padre URL
PADRE_URL=https://trade.padre.gg

# Path to store browser session (cookies/state)
SESSION_DIR=./data/session

# Path to SQLite database
DB_PATH=./data/calls.db

# Path to CSV export directory
CSV_DIR=./data/csv

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Telegram userbot (whale watch ingestion). Get API_ID/API_HASH from
# https://my.telegram.org → API Development Tools. Run `python -m src.telegram_setup`
# once to create the session file.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_PATH=./data/telegram.session
TELEGRAM_CHANNEL=whalewatchsolana
